# ─────────────────────────────────────────────────────────────────────────────
# LAwBOTie – Root .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & Environment Variables ──────────────────────────────────────────
.env
.env.*
!.env.example          # always commit the example/template
*.env
local.env

# ── Node / npm / pnpm ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# ── Next.js (AI-Legal-Advisor frontend) ──────────────────────────────────────
AI-Legal-Advisor/.next/
AI-Legal-Advisor/out/
AI-Legal-Advisor/.vercel/
AI-Legal-Advisor/.cursor/

# ── Spring Boot / Maven (ai-legal-advisor-backend) ────────────────────────────
ai-legal-advisor-backend/**/target/
ai-legal-advisor-backend/**/.mvn/wrapper/maven-wrapper.jar
# The real application.properties contains secrets – never commit it
ai-legal-advisor-backend/**/src/main/resources/application.properties
ai-legal-advisor-backend/**/src/main/resources/application-local.properties
ai-legal-advisor-backend/**/HELP.md

# ── Python AI service ─────────────────────────────────────────────────────────
ai-service/__pycache__/
ai-service/*.pyc
ai-service/*.pyo
ai-service/.venv/
ai-service/venv/
ai-service/env/
ai-service/.env
*.egg-info/
dist/
build/

# ── IDEs & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iws
*.iml
*.ipr
*.swp
*.swo
*~
.project
.classpath
.settings/
.springBeans
.sts4-cache

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Compiled / Build Artifacts ────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz

# ── Misc ─────────────────────────────────────────────────────────────────────
.cache/
coverage/
